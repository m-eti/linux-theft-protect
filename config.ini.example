[Sensor]
# Path to the accelerometer X and Y raw data files
# Leave empty to attempt auto-detection
ACCEL_X_PATH =
ACCEL_Y_PATH =

[Daemon]
# How often to check the sensors, in seconds. (e.g., 0.2 = 5 times per second)
SAMPLE_INTERVAL_SECONDS = 0.2

# The sensitivity threshold. A higher value means less sensitive.
# You will need to experiment to find a good value for your device.
SENSITIVITY_THRESHOLD = 2

# How long (in seconds) the movement must be sustained to trigger the lock.
# Prevents locking from accidental bumps.
TRIGGER_DURATION_SECONDS = 0.5

# Path to the script that locks the screen
# $HOME is expanded to the user's home directory at runtime
LOCKER_SCRIPT_PATH = $HOME/.local/bin/lock-screen.sh

# Number of samples to take during startup calibration.
# Samples are sorted and trimmed (min/max removed) before averaging.
CALIBRATION_SAMPLES = 10

# Size of the sliding window for smoothing live readings.
# Higher values produce smoother readings but add lag.
READING_WINDOW_SIZE = 5

# Dead zone subtracted from movement magnitude before threshold check.
# This filters out constant electrical noise (e.g., 2 = ignore deltas up to 2).
DEAD_ZONE = 1

# Ignore movement when the laptop lid is closed (read from ACPI).
# Prevents useless lock attempts when laptop is in a bag.
IGNORE_LID_CLOSED = true
